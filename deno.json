{
  "tasks": {
    "dev": "deno run --allow-net --allow-env --allow-read --allow-write --env --watch main.ts",
    "build_linux_arm64": "deno compile --allow-net --allow-env --allow-read --allow-write --target aarch64-unknown-linux-gnu -o dyndns_arm64 main.ts",
    "build_linux_amd64": "deno compile --allow-net --allow-env --allow-read --allow-write --target x86_64-unknown-linux-gnu -o dyndns_amd64 main.ts",
    "build_windows": "deno compile --allow-net --allow-env --allow-read --allow-write --target x86_64-pc-windows-msvc -o build/dyndns.exe main.ts",
    "build": "deno task build_linux_arm64 && deno task build_linux_amd64",
    "lint": "deno lint",
    "format": "deno fmt --check"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1"
  }
}
